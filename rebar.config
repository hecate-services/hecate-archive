%% -*- mode: erlang -*-
%% rebar3 configuration for hecate_archive
%%
%% Layer-2 hecate-om service: the COLLECTOR in the sensor family. Many sensors
%% (hecate-grid, hecate-weather, ...) publish verbatim observation facts onto the
%% mesh; this one service persists them, append-only, forever.
%%
%% Same cardinality as warden -> sentinel: N lightweight observers, one collector
%% that holds the record.
%%
%% NO RECKON-DB. The archive holds an append-only tape of sealed segment files,
%% not an event store: no store_id/0 + data_dir/0, so hecate_om:boot/1 wires the
%% mesh and starts no store. The tape is write-only at runtime — nothing in the
%% running system ever reads a sealed segment back.

{erl_opts, [debug_info, warnings_as_errors]}.

{deps, [
    %% The shared L2 substrate: mesh SDK + realm identity + capabilities +
    %% health. Brings macula transitively, which is where macula_cbor_nif (the
    %% at-rest encoding) comes from. gzip is OTP's own zlib — no extra dep.
    {hecate_om, "~> 0.6"}
]}.

{project_plugins, [rebar3_ex_doc, rebar3_lint]}.

%% Elvis: the org's structural ruleset. No deep nesting (HARD, one level), no
%% nested try/catch, no if. Run via `rebar3 lint`.
{elvis, [
    {rulesets, #{
        macula_min => [
            {elvis_style, no_deep_nesting, #{level => 2}},
            {elvis_style, no_nested_try_catch, #{}},
            {elvis_style, no_if_expression, #{}}
        ]
    }},
    {config, [
        #{files => ["apps/*/src/**/*.erl"], ruleset => macula_min}
    ]}
]}.

{relx, [
    {release, {hecate_archive, "0.1.0"}, [hecate_archive, sasl]},
    {sys_config_src, "config/sys.config.src"},
    {vm_args_src,    "config/vm.args.src"},
    {extended_start_script, true}
]}.

{profiles, [
    {prod, [{relx, [{mode, prod},
                    {include_src, false},
                    {include_erts, true},
                    {debug_info, strip}]}]}
]}.

{dialyzer, [
    {warnings, [no_unknown]},
    {exclude_apps, [
        macula, macula_envy, macula_mdns,
        reckon_db, reckon_evoq, reckon_gater, evoq,
        khepri, ra, horus, aten, seshat, gen_batch_server,
        gproc, msgpack, cowboy, ranch, jsx
    ]}
]}.

{shell, [{apps, [hecate_archive]}]}.

{ex_doc, [
    {source_url, <<"https://codeberg.org/hecate-services/hecate-archive">>},
    {extras, ["README.md", "CHANGELOG.md", "LICENSE"]},
    {main, "README.md"}
]}.
